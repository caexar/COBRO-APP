# ------------------------------------------------------------------------------------------
# Aplicación
# ------------------------------------------------------------------------------------------
APP_NAME=CobroApp
# local | testing | production. En Laravel Cloud siempre debe ser "production".
APP_ENV=local
# Generar con `php artisan key:generate` — nunca reutilizar la misma clave entre entornos.
APP_KEY=
# En producción SIEMPRE debe ser false (nunca exponer stack traces/detalles internos).
APP_DEBUG=true
# URL pública de este backend (sin slash final). En producción, la URL real con https://,
# ej: https://api.tudominio.com — Laravel la usa para generar links absolutos y para
# derivar MAIL_EHLO_DOMAIN.
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------------------
# "stderr" es lo recomendado en producción en Laravel Cloud (el filesystem no es persistente
# entre despliegues, así que un log en storage/logs se perdería; Laravel Cloud captura stderr
# directo en su agregador de logs). En desarrollo local, "stack" (con LOG_STACK=single, que
# escribe a storage/logs/laravel.log) sigue siendo más cómodo para tail -f mientras se
# programa — descomentar esa línea y comentar la de stderr para volver a ese comportamiento.
LOG_CHANNEL=stderr
# LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ------------------------------------------------------------------------------------------
# Base de datos
# ------------------------------------------------------------------------------------------
# El proyecto usa MySQL en desarrollo y producción (nombre de base de datos: "cobro_app",
# ver CLAUDE.md). SQLite solo se usa automáticamente en los tests (ver phpunit.xml,
# DB_DATABASE=:memory:) — no hace falta tocar estas variables para correr la suite de tests.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cobro_app
DB_USERNAME=root
DB_PASSWORD=
# Alternativa para desarrollo rápido sin MySQL instalado (comentar las de arriba):
# DB_CONNECTION=sqlite
# DB_DATABASE=/ruta/absoluta/a/database/database.sqlite

# ------------------------------------------------------------------------------------------
# Sesión (panel de administración web, guard "web" — ver CLAUDE.md) y Sanctum (API móvil,
# guard "sanctum"/token). Ambos coexisten sin tocarse: el panel web nunca emite tokens de
# Sanctum, y la API móvil nunca crea una sesión de cookie.
# ------------------------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Dominio de la cookie de sesión del panel admin. En local, dejar "null" (funciona tal cual
# en localhost). En producción, el dominio del panel SIN protocolo ni puerto — normalmente
# con un punto al inicio para que también cubra subdominios, ej:
#   SESSION_DOMAIN=.tudominio.com
SESSION_DOMAIN=null
# Si la cookie de sesión solo viaja por HTTPS. En local puede quedar en false; en producción
# SIEMPRE debe ser true (Laravel Cloud sirve todo por HTTPS).
#   SESSION_SECURE_COOKIE=true
SESSION_SECURE_COOKIE=false

# Dominios desde los que una petición con cookie de sesión se trata como "stateful" (solo
# relevante si algún día se agrega una SPA que consuma la API con cookies en vez de token —
# hoy la app móvil siempre usa Bearer token, nunca cookies, así que esto no la afecta). En
# producción, el/los dominio(s) reales desde donde se sirve un frontend que hable con esta
# API por cookie, separados por coma y CON puerto si no es el estándar, ej:
#   SANCTUM_STATEFUL_DOMAINS=admin.tudominio.com
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1
# SANCTUM_TOKEN_PREFIX=

# ------------------------------------------------------------------------------------------
# Broadcasting, filesystem, colas y caché
# ------------------------------------------------------------------------------------------
BROADCAST_CONNECTION=log
# Disco por defecto. El backend no persiste archivos subidos por el usuario (no hay upload de
# fotos ni similar del lado servidor — ver CLAUDE.md, la foto de cliente es un path local del
# dispositivo móvil) ni escribe archivos temporales que deban sobrevivir entre requests: los
# exports (.xlsx del panel web, JSON del reporte para mobile) se generan en memoria y se
# devuelven directo en la respuesta HTTP (`Excel::raw()`), sin tocar disco. Por eso el
# filesystem efímero de Laravel Cloud (no persiste entre despliegues) no es un problema hoy.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ------------------------------------------------------------------------------------------
# Correo (sin uso funcional hoy — ningún flujo del negocio envía email; se deja el driver
# "log" tal cual viene del esqueleto de Laravel, sin necesidad de credenciales reales)
# ------------------------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------------------
# AWS (sin uso funcional hoy — solo queda por si en el futuro se necesita el disco "s3" de
# filesystems.php; no hace falta completarlo para desplegar)
# ------------------------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
